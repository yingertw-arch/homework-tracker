rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 只開放 App 實際使用的兩個 collection，且必須通過（匿名）驗證。
    // 此規則永久有效，不會像「測試模式」30 天後自動過期。

    match /settings/{doc} {
      allow read, write: if request.auth != null;
    }

    match /data/{doc} {
      allow read, write: if request.auth != null;
    }

    // 其餘所有路徑一律拒絕（預設 deny）。
  }
}
